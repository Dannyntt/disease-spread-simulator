    if not historias:
        print("\n[ERROR] No se encontraron archivos SIR.")
        print("Primero ejecuta el simulador C++ para generar los CSV en ./resultados/")
        return False

    if nodos is None or aristas is None:
        print("\n[ERROR] Faltan archivos del grafo.")
        print("Se esperaban grafo_nodos.csv y grafo_aristas.csv en ./resultados/")
        return False

    return True


# ============================================================
# CARGA DE DATOS
# ============================================================

historias = {k: cargar(f"sir_{k}.csv") for k in ESTRATEGIAS}

nodos         = cargar("grafo_nodos.csv")
