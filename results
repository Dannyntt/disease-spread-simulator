def cargar(nombre):
    path = os.path.join(OUT, nombre)

    if not os.path.exists(path):
        print(f"  [ADVERTENCIA] No encontrado: {path}")
        return None

    try:
        return pd.read_csv(path)
    except Exception as e:
        print(f"  [ERROR] No se pudo leer {path}: {e}")
        return None


def limpiar_ejes(ax):
    ax.grid(True, zorder=0)
    ax.spines["top"].set_visible(False)
    ax.spines["right"].set_visible(False)
    ax.spines["left"].set_color(COLORES["borde"])
    ax.spines["bottom"].set_color(COLORES["borde"])
    ax.tick_params(axis="both", labelsize=9)


def guardar(fig, nombre):
    path = os.path.join(OUT, nombre)
    fig.savefig(path, dpi=300, bbox_inches="tight", facecolor=COLORES["bg"])
    plt.close(fig)
    print(f"[✓] {nombre}")


