def fig2_comparacion():
    fig, axes = plt.subplots(1, 3, figsize=(17, 6))
    fig.suptitle(
        "Comparación de estrategias de contención",
        fontsize=15,
        fontweight="bold",
        color=COLORES["texto"],
        y=1.03,
    )

    claves = [k for k in ESTRATEGIAS if k in historias]
    labels = [ESTRATEGIAS[k][0] for k in claves]
    colores = [ESTRATEGIAS[k][1] for k in claves]

    picos = [int(historias[k]["I"].max()) for k in claves]
    total_r = [int(historias[k]["R"].iloc[-1]) for k in claves]

    baseline = picos[claves.index("ninguna")] if "ninguna" in claves else max(picos)

    # Pico de infectados
    ax = axes[0]
    limpiar_ejes(ax)

    bars = ax.bar(
        labels,
        picos,
        color=colores,
        alpha=0.90,
        width=0.62,
        edgecolor="#ffffff",
        linewidth=1.2,
        zorder=3,
    )

    for bar, val in zip(bars, picos):
        pct = 100 * (baseline - val) / baseline
        ax.text(
            bar.get_x() + bar.get_width() / 2,
            val + 6,
            f"{val}",
            ha="center",
            fontsize=9,
            fontweight="bold",
            color=COLORES["texto"],
        )

        if pct > 0:
            ax.text(
                bar.get_x() + bar.get_width() / 2,
                val * 0.55,
                f"-{pct:.1f}%",
                ha="center",
                fontsize=9,
                fontweight="bold",
                color="#ffffff",
            )

    ax.set_title("Pico máximo de infectados", color=COLORES["texto"])
    ax.set_ylabel("Nodos infectados")
    ax.tick_params(axis="x", rotation=18)
    ax.grid(True, axis="y")

    # Curvas de infectados
    ax = axes[1]
    limpiar_ejes(ax)

    for clave, (label, color) in ESTRATEGIAS.items():
        if clave not in historias:
            continue

        df = historias[clave]
        ax.plot(
            df["tick"],
            df["I"],
            label=label,
            color=color,
            lw=3.0 if clave == "ninguna" else 2.4,
            ls="--" if clave == "ninguna" else "-",
        )

    ax.set_title("Evolución de infectados", color=COLORES["texto"])
    ax.set_xlabel("Días")
    ax.set_ylabel("Infectados")
    ax.legend(fontsize=8)

    # Total recuperados / afectados
    ax = axes[2]
    limpiar_ejes(ax)

    bars = ax.bar(
        labels,
        total_r,
        color=colores,
        alpha=0.90,
        width=0.62,
        edgecolor="#ffffff",
        linewidth=1.2,
        zorder=3,
    )

    for bar, val in zip(bars, total_r):
        ax.text(
            bar.get_x() + bar.get_width() / 2,
            val + 6,
            f"{val}",
            ha="center",
            fontsize=9,
            fontweight="bold",
            color=COLORES["texto"],
        )

    ax.set_title("Total acumulado al final de la simulación", color=COLORES["texto"])
    ax.set_ylabel("Nodos en estado R")
    ax.tick_params(axis="x", rotation=18)
    ax.grid(True, axis="y")

    plt.tight_layout()
    guardar(fig, "fig2_comparacion.png")



def fig3_grafo():
    if nodos is None or aristas is None:
        print("[!] fig3 omitida: faltan grafo_nodos.csv o grafo_aristas.csv")
        return

    G = nx.Graph()

    color_mapa = {
        "S": COLORES["S"],
        "I": COLORES["I"],
        "R": COLORES["R"],
    }

    for _, row in nodos.iterrows():
        G.add_node(
            row["id"],
            estado=row.get("estado", "S"),
            tipo=row.get("tipo", ""),
            depto=row.get("depto", ""),
        )

    for _, row in aristas.iterrows():
        G.add_edge(
            row["origen"],
            row["destino"],
            weight=row.get("peso", 1.0),
        )

    comps = sorted(nx.connected_components(G), key=len, reverse=True)

    if not comps:
        print("[!] fig3 omitida: el grafo está vacío")
        return

    G_giant = G.subgraph(comps[0]).copy()

    fig, axes = plt.subplots(1, 2, figsize=(16, 7))
    fig.suptitle(
        "Estructura de la red de contagio",
        fontsize=15,
        fontweight="bold",
        color=COLORES["texto"],
        y=1.02,
    )

    graficos = [
        (G_giant, f"Componente gigante\n{G_giant.number_of_nodes()} nodos"),
        (G, f"Grafo completo\n{G.number_of_nodes()} nodos, {G.number_of_edges()} aristas"),
    ]

    for ax, (G_plot, titulo) in zip(axes, graficos):
        ax.set_title(titulo, color=COLORES["texto"], fontsize=12)
        ax.set_facecolor("#f1f5f9")

        pos = nx.spring_layout(G_plot, seed=42, k=0.6)

        node_colors = [
            color_mapa.get(G_plot.nodes[n].get("estado", "S"), COLORES["S"])
            for n in G_plot.nodes()
        ]

        node_sizes = [
            18 + G_plot.degree(n) * 10
            for n in G_plot.nodes()
        ]

        edge_widths = [
            max(0.3, G_plot[u][v].get("weight", 0.5) * 1.8)
            for u, v in G_plot.edges()
        ]

        nx.draw_networkx_edges(
            G_plot,
            pos,
            ax=ax,
            alpha=0.18,
            edge_color="#64748b",
            width=edge_widths,
        )

        nx.draw_networkx_nodes(
            G_plot,
            pos,
            ax=ax,
            node_color=node_colors,
            node_size=node_sizes,
            alpha=0.88,
            linewidths=0.35,
            edgecolors="#ffffff",
        )

        hubs = {
            n: str(n)
            for n in G_plot.nodes()
            if G_plot.degree(n) >= 5
        }

        nx.draw_networkx_labels(
            G_plot,
            pos,
            labels=hubs,
            ax=ax,
            font_size=6,
            font_color=COLORES["texto"],
        )

        ax.axis("off")

    leyenda = [
        mpatches.Patch(color=COLORES["I"], label="Infectado / importado"),
        mpatches.Patch(color=COLORES["S"], label="Susceptible"),
        mpatches.Patch(color=COLORES["R"], label="Recuperado"),
    ]

    fig.legend(
        handles=leyenda,
        loc="lower center",
        ncol=3,
        fontsize=9,
        frameon=True,
    )

    plt.tight_layout(rect=[0, 0.05, 1, 1])
    guardar(fig, "fig3_grafo.png")



def fig4_analisis_red():
    if grados_df is None or centralidades is None or componentes is None:
        print("[!] fig4 omitida: faltan archivos de métricas de red")
        return

    fig, axes = plt.subplots(2, 2, figsize=(15, 10))
    fig.suptitle(
        "Métricas estructurales de la red de contagio",
        fontsize=15,
        fontweight="bold",
        color=COLORES["texto"],
        y=1.02,
    )

    # Distribución de grados
    ax = axes[0, 0]
    limpiar_ejes(ax)

    gv = grados_df["grado"]

    ax.hist(
        gv,
        bins=range(0, int(gv.max()) + 2),
        color=COLORES["acento"],
        alpha=0.85,
        edgecolor="#ffffff",
        linewidth=0.8,
        zorder=3,
    )

    ax.axvline(
        gv.mean(),
        color=COLORES["I"],
        lw=2,
        ls="--",
        label=f"Media: {gv.mean():.2f}",
    )

    ax.set_title("Distribución de grados")
    ax.set_xlabel("Grado")
    ax.set_ylabel("Frecuencia")
    ax.legend(fontsize=8)
    ax.grid(True, axis="y")

    # Boxplot por tipo
    ax = axes[0, 1]
    limpiar_ejes(ax)

    tipos_unicos = grados_df["tipo"].dropna().unique()

    col_tipo = {
        "Importado": COLORES["I"],
        "Relacionado": COLORES["acento"],
        "En estudio": COLORES["S"],
    }

    data_tipo = [
        grados_df[grados_df["tipo"] == t]["grado"].values
        for t in tipos_unicos
    ]

    bp = ax.boxplot(
        data_tipo,
        patch_artist=True,
        medianprops=dict(color="#ffffff", lw=2),
        boxprops=dict(linewidth=1.0),
        whiskerprops=dict(color=COLORES["gris"]),
        capprops=dict(color=COLORES["gris"]),
    )

    for patch, tipo in zip(bp["boxes"], tipos_unicos):
        patch.set_facecolor(col_tipo.get(tipo, COLORES["grid"]))
        patch.set_alpha(0.82)
        patch.set_edgecolor("#ffffff")

    ax.set_xticklabels(tipos_unicos, rotation=10)
    ax.set_title("Grado por tipo de caso")
    ax.set_ylabel("Grado")
    ax.grid(True, axis="y")

    # Centralidad grado vs betweenness
    ax = axes[1, 0]
    limpiar_ejes(ax)

    for tipo, color in [
        ("Importado", COLORES["I"]),
        ("Relacionado", COLORES["acento"]),
        ("En estudio", COLORES["S"]),
    ]:
        sub = centralidades[centralidades["tipo"] == tipo]

        if len(sub) == 0:
            continue

        ax.scatter(
            sub["centralidad_grado"],
            sub["betweenness"],
            alpha=0.62,
            s=22,
            color=color,
            label=tipo,
            edgecolor="#ffffff",
            linewidth=0.35,
        )

    ax.set_title("Centralidad de grado vs betweenness")
    ax.set_xlabel("Centralidad de grado")
    ax.set_ylabel("Betweenness")
    ax.legend(fontsize=8)

    # Componentes conexas
    ax = axes[1, 1]
    limpiar_ejes(ax)

    tam_comps = componentes.groupby("componente_id")["tamano_componente"].first()
    freq = tam_comps.value_counts().sort_index()

    ax.bar(
        freq.index.astype(str),
        freq.values,
        color=COLORES["acento2"],
        alpha=0.88,
        edgecolor="#ffffff",
        linewidth=0.8,
        zorder=3,
    )

    ax.set_title(f"Componentes conexas ({len(tam_comps)} componentes)")
    ax.set_xlabel("Tamaño de componente")
    ax.set_ylabel("Número de componentes")
    ax.tick_params(axis="x", rotation=30)
    ax.grid(True, axis="y")

    plt.tight_layout()
    guardar(fig, "fig4_analisis_red.png")



def fig5_departamentos():
    if nodos is None or grados_df is None:
        print("[!] fig5 omitida: faltan nodos o grados")
        return

    fig, axes = plt.subplots(1, 3, figsize=(17, 6))
    fig.suptitle(
        "Distribución territorial de casos y conectividad",
        fontsize=15,
        fontweight="bold",
        color=COLORES["texto"],
        y=1.03,
    )

    # Top departamentos
    ax = axes[0]
    limpiar_ejes(ax)

    top = nodos["depto"].value_counts().head(10)

    ax.barh(
        top.index[::-1],
        top.values[::-1],
        color=COLORES["acento"],
        alpha=0.88,
        edgecolor="#ffffff",
        linewidth=0.8,
        zorder=3,
    )

    for i, val in enumerate(top.values[::-1]):
        ax.text(
            val + 1,
            i,
            str(val),
            va="center",
            fontsize=8,
            color=COLORES["texto"],
            fontweight="bold",
        )

    ax.set_title("Top 10 departamentos por número de casos")
    ax.set_xlabel("Número de casos")
    ax.grid(True, axis="x")

    # Composición SIR por departamento
    ax = axes[1]
    limpiar_ejes(ax)

    top_deptos = nodos["depto"].value_counts().head(8).index
    sub = nodos[nodos["depto"].isin(top_deptos)]

    pivot = sub.groupby(["depto", "estado"]).size().unstack(fill_value=0)
    pivot["total"] = pivot.sum(axis=1)
    pivot = pivot.sort_values("total", ascending=True).drop("total", axis=1)

    bottom = np.zeros(len(pivot))

    for estado, color in [
        ("S", COLORES["S"]),
        ("I", COLORES["I"]),
        ("R", COLORES["R"]),
    ]:
        if estado in pivot.columns:
            vals = pivot[estado].values
            ax.barh(
                pivot.index,
                vals,
                left=bottom,
                color=color,
                alpha=0.88,
                label=estado,
                edgecolor="#ffffff",
                linewidth=0.4,
                zorder=3,
            )
            bottom += vals

    ax.set_title("Composición SIR por departamento")
    ax.set_xlabel("Nodos")
    ax.legend(fontsize=8)
    ax.grid(True, axis="x")

    # Grado promedio por departamento
    ax = axes[2]
    limpiar_ejes(ax)

    grado_depto = (
        grados_df.groupby("depto")["grado"]
        .mean()
        .sort_values(ascending=False)
        .head(10)
    )

    ax.barh(
        grado_depto.index[::-1],
        grado_depto.values[::-1],
        color=COLORES["R"],
        alpha=0.88,
        edgecolor="#ffffff",
        linewidth=0.8,
        zorder=3,
    )

    for i, val in enumerate(grado_depto.values[::-1]):
        ax.text(
            val + 0.02,
            i,
            f"{val:.2f}",
            va="center",
            fontsize=8,
            color=COLORES["texto"],
            fontweight="bold",
        )

    ax.set_title("Conectividad promedio por departamento")
    ax.set_xlabel("Grado promedio")
    ax.grid(True, axis="x")

    plt.tight_layout()
    guardar(fig, "fig5_departamentos.png")


def fig6_resumen():
    fig = plt.figure(figsize=(16, 9))
    gs = gridspec.GridSpec(2, 3, hspace=0.5, wspace=0.4, figure=fig)

    fig.suptitle(
        "Resumen comparativo del simulador epidemiológico SIR",
        fontsize=15,
        fontweight="bold",
        color=COLORES["texto"],
        y=1.02,
    )

    # Heatmap SIR 
    ax = fig.add_subplot(gs[0, :2])
    limpiar_ejes(ax)

    if "ninguna" in historias:
        df = historias["ninguna"]

        matriz = np.array([
            df["S"].values,
            df["I"].values,
            df["R"].values,
        ])

        im = ax.imshow(
            matriz,
            aspect="auto",
            cmap="viridis",
            interpolation="nearest",
        )

        ax.set_yticks([0, 1, 2])
        ax.set_yticklabels(["S", "I", "R"])
        ax.set_xlabel("Días")
        ax.set_title("Evolución SIR sin intervención")

        cbar = plt.colorbar(im, ax=ax, shrink=0.82)
        cbar.set_label("Nodos")

    # Tabla de métricas
    ax = fig.add_subplot(gs[0, 2])
    ax.set_facecolor(COLORES["panel"])
    ax.axis("off")

    claves = [k for k in ESTRATEGIAS if k in historias]
    picos = [int(historias[k]["I"].max()) for k in claves]
    dias_p = [
        int(historias[k].loc[historias[k]["I"].idxmax(), "tick"])
        for k in claves
    ]

    base = picos[claves.index("ninguna")] if "ninguna" in claves else max(picos)

    tabla_d = [
        [
            ESTRATEGIAS[k][0][:18],
            str(p),
            str(d),
            f"{100 * (base - p) / base:.1f}%",
        ]
        for k, p, d in zip(claves, picos, dias_p)
    ]

    tabla = ax.table(
        cellText=tabla_d,
        colLabels=["Estrategia", "Pico I", "Día", "Reducción"],
        cellLoc="center",
        loc="center",
    )

    tabla.auto_set_font_size(False)
    tabla.set_fontsize(8)
    tabla.scale(1, 1.6)

    for (r, c), cell in tabla.get_celld().items():
        if r == 0:
            cell.set_facecolor(COLORES["acento"])
            cell.set_text_props(color="#ffffff", fontweight="bold")
        else:
            cell.set_facecolor("#ffffff")
            cell.set_text_props(color=COLORES["texto"])

        cell.set_edgecolor(COLORES["borde"])

    ax.set_title("Indicadores principales", color=COLORES["texto"], fontweight="bold")

    # Curvas finales de infectados
    ax = fig.add_subplot(gs[1, :])
    limpiar_ejes(ax)

    for clave, (label, color) in ESTRATEGIAS.items():
        if clave in historias:
            df = historias[clave]
            ax.fill_between(
                df["tick"],
                df["I"],
                alpha=0.12,
                color=color,
            )
            ax.plot(
