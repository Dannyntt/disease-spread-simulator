def fig1_curvas_sir():
    fig, axes = plt.subplots(2, 2, figsize=(15, 9))
    fig.suptitle(
        "Dinámica SIR bajo estrategias de contención\nRed de contagio COVID-19 Colombia",
        fontsize=15,
        fontweight="bold",
        color=COLORES["texto"],
        y=1.02,
    )

    for ax, (clave, (titulo, color_estrategia)) in zip(axes.flat, ESTRATEGIAS.items()):
        if clave not in historias:
            ax.set_visible(False)
            continue

        df = historias[clave]
        limpiar_ejes(ax)

        ax.plot(df["tick"], df["S"], color=COLORES["S"], label="Susceptibles")
        ax.plot(df["tick"], df["I"], color=COLORES["I"], label="Infectados")
        ax.plot(df["tick"], df["R"], color=COLORES["R"], label="Recuperados")

        idx_pico = df["I"].idxmax()
        pico_t = int(df.loc[idx_pico, "tick"])
        pico_v = int(df.loc[idx_pico, "I"])

        ax.scatter(
            pico_t,
            pico_v,
            color=COLORES["I"],
            s=55,
            zorder=5,
            edgecolor="white",
            linewidth=1.1,
        )

        ax.axvline(
            pico_t,
            color=COLORES["I"],
            alpha=0.22,
            lw=1.5,
            ls="--",
        )

        ax.annotate(
            f"Pico: día {pico_t}\n{pico_v} infectados",
            xy=(pico_t, pico_v),
            xytext=(pico_t + 4, max(pico_v * 0.78, 5)),
            fontsize=8,
            color=COLORES["texto"],
            bbox=dict(
                boxstyle="round,pad=0.3",
                facecolor="#ffffff",
                edgecolor=COLORES["borde"],
                alpha=0.95,
            ),
            arrowprops=dict(
                arrowstyle="->",
                color=COLORES["I"],
                lw=1.0,
            ),
        )

        ax.set_title(titulo, color=color_estrategia, fontsize=12)
        ax.set_xlabel("Días desde inicio del brote")
        ax.set_ylabel("Cantidad de nodos")
        ax.legend(fontsize=8, loc="best")

    plt.tight_layout()
    guardar(fig, "fig1_curvas_sir.png")


