# FIGURA 4 — Distribución de grados
# ════════════════════════════════════════════════════════════
def figura4():
    grados_df = pd.read_csv(f"{RUTA}/grafo_grados.csv")
    nodos_df  = pd.read_csv(f"{RUTA}/grafo_nodos.csv")

    fig, axes = plt.subplots(1, 3, figsize=(14, 5))
    fig.suptitle("Network Degree Analysis — COVID-19 Contagion Graph",
                 fontsize=13, fontweight="bold")

    ax = axes[0]
    gv = grados_df["grado"]
    ax.hist(gv, bins=range(0, int(gv.max()) + 2),
            color="#6366f1", alpha=0.8, edgecolor="white")
    ax.axvline(gv.mean(), color="#ef4444", lw=2, ls="--",
               label=f"Mean: {gv.mean():.2f}")
    ax.set_title("Degree Distribution", fontweight="bold")
    ax.set_xlabel("Node degree")
    ax.set_ylabel("Frequency")
    ax.legend()

    ax = axes[1]
    tipos = grados_df["tipo"].unique()
    col_tipo   = {"Importado": COLORES_SIR["I"],
                  "Relacionado": "#6366f1",
                  "En estudio": COLORES_SIR["S"]}
    label_tipo = {"Importado": "Imported",
                  "Relacionado": "Related",
                  "En estudio": "Under study"}
    data = [grados_df[grados_df["tipo"] == t]["grado"].values for t in tipos]
    bp = ax.boxplot(data, patch_artist=True,
                    medianprops=dict(color="white", lw=2))
    for patch, tipo in zip(bp["boxes"], tipos):
        patch.set_facecolor(col_tipo.get(tipo, "#94a3b8"))
        patch.set_alpha(0.75)
    ax.set_xticklabels([label_tipo.get(t, t) for t in tipos], rotation=10)
    ax.set_title("Degree by Case Type", fontweight="bold")
    ax.set_ylabel("Degree")

    ax = axes[2]
    top = nodos_df["depto"].value_counts().head(10)
    ax.barh(top.index[::-1], top.values[::-1],
            color="#6366f1", alpha=0.85, edgecolor="white")
    for i, val in enumerate(top.values[::-1]):
        ax.text(val + 0.3, i, str(val), va="center", fontsize=8)
    ax.set_title("Top 10 Departments by Cases", fontweight="bold")
    ax.set_xlabel("Number of cases")

    plt.tight_layout()
    guardar(fig, "figura4_grados")


