import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import matplotlib.patches as mpatches
import networkx as nx
import os

RUTA = "./resultados"
os.makedirs(RUTA, exist_ok=True)

plt.rcParams.update({
    "font.family":       "serif",
    "font.size":         10,
    "axes.labelsize":    10,
    "axes.titlesize":    12,
    "legend.fontsize":   9,
    "xtick.labelsize":   9,
    "ytick.labelsize":   9,
    "axes.spines.top":   False,
    "axes.spines.right": False,
    "axes.grid":         True,
    "grid.alpha":        0.3,
    "grid.linestyle":    "--",
})

COLORES_SIR = {"S": "#2563eb", "I": "#dc2626", "R": "#16a34a"}

ESTRATEGIAS = {
    "ninguna":     ("No Intervention (Baseline)", "#ef4444", "1a"),
    "hubs":        ("Hub Isolation",              "#f59e0b", "1b"),
    "rastreo_bfs": ("Contact Tracing (BFS)",      "#3b82f6", "1c"),
    "vacunacion":  ("Targeted Vaccination",       "#10b981", "1d"),
}

def guardar(fig, nombre):
    fig.savefig(f"{RUTA}/{nombre}.pdf", dpi=300, bbox_inches="tight")
    fig.savefig(f"{RUTA}/{nombre}.png", dpi=300, bbox_inches="tight")
    plt.close(fig)
    print(f"[OK] {nombre}.pdf/.png")


def figuras_sir():
    for clave, (titulo, color_est, sufijo) in ESTRATEGIAS.items():
        df = pd.read_csv(f"{RUTA}/sir_{clave}.csv")

        fig, ax = plt.subplots(figsize=(8, 5))

        ax.plot(df["tick"], df["S"], color=COLORES_SIR["S"],
                lw=2.2, label="Susceptible (S)")
        ax.plot(df["tick"], df["I"], color=COLORES_SIR["I"],
                lw=2.2, label="Infected (I)")
        ax.plot(df["tick"], df["R"], color=COLORES_SIR["R"],
                lw=2.2, label="Recovered (R)")

        # Marcar pico
        idx = df["I"].idxmax()
        pt  = int(df["tick"][idx])
        pv  = int(df["I"][idx])
        ax.axvline(pt, color=COLORES_SIR["I"],
                   alpha=0.35, ls="--", lw=1.5)
        ax.annotate(
            f"Peak: day {pt}\n({pv} nodes)",
            xy=(pt, pv),
            xytext=(pt + 3, pv * 0.78),
            fontsize=9, color=COLORES_SIR["I"],
            arrowprops=dict(arrowstyle="->",
                            color=COLORES_SIR["I"], lw=1.0),
        )

        # Area rellena bajo la curva I
        ax.fill_between(df["tick"], df["I"],
                        alpha=0.08, color=COLORES_SIR["I"])

        ax.set_title(f"SIR Epidemic Curve — {titulo}", fontweight="bold")
        ax.set_xlabel("Days since outbreak onset")
        ax.set_ylabel("Number of nodes")
        ax.legend(loc="center right")

        # Caja de estadísticas
        total_n = int(df["S"].iloc[0] + df["I"].iloc[0] + df["R"].iloc[0])
        ax.text(0.02, 0.97,
                f"N = {total_n}   |   Peak I = {pv}   |   Peak day = {pt}",
                transform=ax.transAxes, fontsize=8, va="top",
                bbox=dict(boxstyle="round,pad=0.3",
                          facecolor="white", edgecolor="#cbd5e1", alpha=0.8))

        plt.tight_layout()
        guardar(fig, f"figura{sufijo}_sir_{clave}")


def figura2():
    fig, axes = plt.subplots(1, 3, figsize=(14, 5))
    fig.suptitle(
        "Comparison of Containment Strategies — COVID-19 Colombia",
        fontsize=13, fontweight="bold"
    )

    claves  = list(ESTRATEGIAS.keys())
    labels  = [ESTRATEGIAS[k][0] for k in claves]
    colores = [ESTRATEGIAS[k][1] for k in claves]
    picos   = [pd.read_csv(f"{RUTA}/sir_{k}.csv")["I"].max() for k in claves]
    total_r = [pd.read_csv(f"{RUTA}/sir_{k}.csv")["R"].iloc[-1] for k in claves]
    baseline = picos[claves.index("ninguna")]

    # Panel 1: Pico de infectados
    ax = axes[0]
    bars = ax.bar(labels, picos, color=colores, alpha=0.85,
                  edgecolor="white", width=0.55)
    for bar, val in zip(bars, picos):
        pct = 100 * (baseline - val) / baseline
        ax.text(bar.get_x() + bar.get_width()/2, val + 2,
                str(val), ha="center", fontsize=9, fontweight="bold")
        if pct > 0:
            ax.text(bar.get_x() + bar.get_width()/2, val / 2,
                    f"−{pct:.0f}%", ha="center", fontsize=9,
                    color="white", fontweight="bold")
    ax.set_title("Peak Infected Nodes", fontweight="bold")
    ax.set_ylabel("Maximum infected nodes")
    ax.tick_params(axis="x", rotation=15)

    # Panel 2: Curvas I superpuestas
    ax = axes[1]
    for clave, (label, color, _) in ESTRATEGIAS.items():
        df = pd.read_csv(f"{RUTA}/sir_{clave}.csv")
        ax.plot(df["tick"], df["I"], label=label, color=color,
                lw=2.5 if clave == "ninguna" else 1.8,
                ls="--" if clave == "ninguna" else "-")
    ax.set_title("Infected Curves — All Strategies", fontweight="bold")
    ax.set_xlabel("Days since outbreak onset")
    ax.set_ylabel("Infected nodes")
    ax.legend(loc="upper right", fontsize=8)

    # Panel 3: Total recuperados
    ax = axes[2]
    bars = ax.bar(labels, total_r, color=colores, alpha=0.85,
                  edgecolor="white", width=0.55)
    for bar, val in zip(bars, total_r):
        ax.text(bar.get_x() + bar.get_width()/2, val + 2,
                str(val), ha="center", fontsize=9, fontweight="bold")
    ax.set_title("Total Affected Nodes (day 60)", fontweight="bold")
    ax.set_ylabel("Nodes in state R")
    ax.tick_params(axis="x", rotation=15)

    plt.tight_layout()
    guardar(fig, "figura2_comparacion")


