def figura6():
    redes = {
        "sir_ninguna.csv":          ("Real network",    "#ef4444", "-"),
        "sir_Aleatoria (ER).csv":   ("Erdős–Rényi",     "#6366f1", "--"),
        "sir_Small-World (WS).csv": ("Watts–Strogatz",  "#f59e0b", "-."),
        "sir_Scale-Free (BA).csv":  ("Barabási–Albert", "#10b981", ":"),
    }

    fig, axes = plt.subplots(1, 3, figsize=(15, 5))
    fig.suptitle(
        "Epidemic Dynamics Across Network Topologies\n"
        "Real network vs Synthetic models",
        fontsize=13, fontweight="bold"
    )

    for ax, (col, tit) in zip(axes, [("S","Susceptible (S)"),
                                      ("I","Infected (I)"),
                                      ("R","Recovered (R)")]):
        for archivo, (label, color, ls) in redes.items():
            df = pd.read_csv(f"{RUTA}/{archivo}")
            ax.plot(df["tick"], df[col], label=label,
                    color=color, lw=2, ls=ls)
        ax.set_title(tit, fontweight="bold")
        ax.set_xlabel("Days since outbreak onset")
        ax.set_ylabel("Nodes")
        ax.legend(fontsize=8)

    plt.tight_layout()
    guardar(fig, "figura6_sinteticas")


