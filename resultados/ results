# FIGURA 5 — Centralidades
# ════════════════════════════════════════════════════════════
def figura5():
    cent = pd.read_csv(f"{RUTA}/grafo_centralidades.csv")

    fig, axes = plt.subplots(1, 2, figsize=(12, 5))
    fig.suptitle("Centrality Analysis — COVID-19 Contagion Network",
                 fontsize=13, fontweight="bold")

    col_tipo   = {"Importado": COLORES_SIR["I"],
                  "Relacionado": "#6366f1",
                  "En estudio": COLORES_SIR["S"]}
    label_tipo = {"Importado": "Imported",
                  "Relacionado": "Related",
                  "En estudio": "Under study"}

    ax = axes[0]
    for tipo, color in col_tipo.items():
        sub = cent[cent["tipo"] == tipo]
        ax.scatter(sub["centralidad_grado"], sub["betweenness"],
                   alpha=0.6, s=20, color=color,
                   label=label_tipo.get(tipo, tipo))
    top5 = cent.nlargest(5, "betweenness")
    for _, row in top5.iterrows():
        ax.annotate(f"ID {int(row['id'])}",
                    xy=(row["centralidad_grado"], row["betweenness"]),
                    xytext=(row["centralidad_grado"] + 0.002,
                            row["betweenness"] + 0.001),
                    fontsize=7)
    ax.set_title("Degree Centrality vs Betweenness Centrality",
                 fontweight="bold")
    ax.set_xlabel("Degree centrality $C_D(v)$")
    ax.set_ylabel("Betweenness centrality $C_B(v)$")
    ax.legend()

    ax = axes[1]
    top15 = cent.nlargest(15, "betweenness").sort_values("betweenness")
    colores_bar = [col_tipo.get(t, "#94a3b8") for t in top15["tipo"]]
    ax.barh([f"ID {int(i)}" for i in top15["id"]],
            top15["betweenness"], color=colores_bar,
            alpha=0.85, edgecolor="white")
    ax.set_title("Top 15 Nodes by Betweenness Centrality", fontweight="bold")
    ax.set_xlabel("Betweenness centrality $C_B(v)$")
    leyenda = [mpatches.Patch(color=c, label=label_tipo.get(t, t))
               for t, c in col_tipo.items()]
    ax.legend(handles=leyenda, fontsize=8)

    plt.tight_layout()
    guardar(fig, "figura5_centralidades")


