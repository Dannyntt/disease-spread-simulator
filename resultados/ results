# FIGURA 3 — Red de contagio
# ════════════════════════════════════════════════════════════
def figura3():
    nodos_df   = pd.read_csv(f"{RUTA}/grafo_nodos.csv")
    aristas_df = pd.read_csv(f"{RUTA}/grafo_aristas.csv")

    G = nx.Graph()
    color_map = {"S": COLORES_SIR["S"],
                 "I": COLORES_SIR["I"],
                 "R": COLORES_SIR["R"]}

    for _, row in nodos_df.iterrows():
        G.add_node(row["id"], estado=row["estado"],
                   tipo=row["tipo"], depto=row["depto"])
    for _, row in aristas_df.iterrows():
        G.add_edge(row["origen"], row["destino"], weight=row["peso"])

    comps   = sorted(nx.connected_components(G), key=len, reverse=True)
    G_giant = G.subgraph(comps[0]).copy()

    fig, axes = plt.subplots(1, 2, figsize=(14, 6))
    fig.suptitle("COVID-19 Contagion Network — Colombia",
                 fontsize=13, fontweight="bold")

    for ax, (G_plot, titulo) in zip(axes, [
        (G_giant, f"Giant Component\n({G_giant.number_of_nodes()} nodes, "
                  f"{G_giant.number_of_edges()} edges)"),
        (G,       f"Full Graph\n({G.number_of_nodes()} nodes, "
                  f"{G.number_of_edges()} edges)"),
    ]):
        pos = nx.spring_layout(G_plot, seed=42, k=0.6)
        colores_nodos = [color_map.get(G_plot.nodes[n].get("estado", "S"),
                                       COLORES_SIR["S"])
                         for n in G_plot.nodes()]
        sizes  = [15 + G_plot.degree(n) * 12 for n in G_plot.nodes()]
        pesos  = [G_plot[u][v].get("weight", 0.5) for u, v in G_plot.edges()]

        nx.draw_networkx_edges(G_plot, pos, ax=ax, alpha=0.3,
                               edge_color="#94a3b8",
                               width=[p * 2 for p in pesos])
        nx.draw_networkx_nodes(G_plot, pos, ax=ax,
                               node_color=colores_nodos,
                               node_size=sizes, alpha=0.9)
        hubs = {n: str(n) for n in G_plot.nodes() if G_plot.degree(n) >= 5}
        nx.draw_networkx_labels(G_plot, pos, labels=hubs,
                                ax=ax, font_size=6)
        ax.set_title(titulo, fontweight="bold")
        ax.axis("off")

    leyenda = [
        mpatches.Patch(color=COLORES_SIR["I"], label="Imported (seed I)"),
        mpatches.Patch(color=COLORES_SIR["S"], label="Susceptible (S)"),
        mpatches.Patch(color=COLORES_SIR["R"], label="Recovered (R)"),
    ]
    fig.legend(handles=leyenda, loc="lower center", ncol=3, fontsize=9)
    plt.tight_layout()
    guardar(fig, "figura3_grafo")


