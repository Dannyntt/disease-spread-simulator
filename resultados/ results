# FIGURA 7 — Dijkstra
# ════════════════════════════════════════════════════════════
def figura7():
    try:
        cadena = pd.read_csv(f"{RUTA}/cadena_contagio.csv")
    except FileNotFoundError:
        print("[!] figura7 omitida: no se encontró cadena_contagio.csv")
        return

    nodos_df   = pd.read_csv(f"{RUTA}/grafo_nodos.csv")
    aristas_df = pd.read_csv(f"{RUTA}/grafo_aristas.csv")

    G = nx.Graph()
    for _, row in nodos_df.iterrows():
        G.add_node(row["id"], estado=row["estado"], depto=row["depto"])
    for _, row in aristas_df.iterrows():
        G.add_edge(row["origen"], row["destino"], weight=row["peso"])

    ids_camino = list(cadena["nodo_id"])
    comps      = sorted(nx.connected_components(G), key=len, reverse=True)
    G_giant    = G.subgraph(comps[0]).copy()
    pos        = nx.spring_layout(G_giant, seed=42, k=0.8)

    fig, axes = plt.subplots(1, 2, figsize=(14, 6))
    fig.suptitle(
        " Contagion Chain — Dijkstra's Algorithm\n"
        f"Path: {' → '.join(map(str, ids_camino))}",
        fontsize=12, fontweight="bold"
    )

    ax = axes[0]
    color_map = {"S": COLORES_SIR["S"],
                 "I": COLORES_SIR["I"],
                 "R": COLORES_SIR["R"]}
    colores_nodos = [color_map.get(G_giant.nodes[n].get("estado", "S"),
                                    COLORES_SIR["S"])
                     for n in G_giant.nodes()]
    sizes = [30 + G_giant.degree(n) * 15 for n in G_giant.nodes()]

    nx.draw_networkx_edges(G_giant, pos, ax=ax,
                           alpha=0.2, edge_color="#94a3b8")
    nx.draw_networkx_nodes(G_giant, pos, ax=ax,
                           node_color=colores_nodos,
                           node_size=sizes, alpha=0.8)

    camino_edges = [(ids_camino[i], ids_camino[i+1])
                    for i in range(len(ids_camino)-1)
                    if G_giant.has_node(ids_camino[i]) and
                       G_giant.has_node(ids_camino[i+1])]
    nx.draw_networkx_edges(G_giant, pos, edgelist=camino_edges,
                           ax=ax, edge_color="#f59e0b", width=4, alpha=0.9)
    camino_nodos = [n for n in ids_camino if G_giant.has_node(n)]
    nx.draw_networkx_nodes(G_giant, pos, nodelist=camino_nodos,
                           ax=ax, node_color="#f59e0b",
                           node_size=300, alpha=1.0)
    nx.draw_networkx_labels(G_giant, pos,
                            labels={n: str(n) for n in camino_nodos},
                            ax=ax, font_size=8, font_weight="bold")
    ax.set_title("Contagion path in giant component", fontweight="bold")
    ax.axis("off")

    ax = axes[1]
    ax.axis("off")
    tabla_datos = [
        [int(row["paso"]), int(row["nodo_id"]),
         row["depto"], row["ciudad"], row["fecha"], row["estado"]]
        for _, row in cadena.iterrows()
    ]
    tabla = ax.table(
        cellText=tabla_datos,
        colLabels=["Step","Case ID","Department","City","Date","State"],
        cellLoc="center", loc="center"
    )
    tabla.auto_set_font_size(False)
    tabla.set_fontsize(9)
    tabla.scale(1.2, 1.8)
    for j in range(6):
        tabla[(0, j)].set_facecolor("#1e293b")
        tabla[(0, j)].set_text_props(color="white", fontweight="bold")
    ax.set_title("Contagion chain step by step", fontweight="bold", pad=20)

    plt.tight_layout()
    guardar(fig, "figura7_dijkstra")



